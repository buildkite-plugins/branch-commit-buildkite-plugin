#!/bin/bash

set -euo pipefail

DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

# shellcheck source=lib/plugin.bash
. "$DIR/../lib/plugin.bash"

# Only run for UI-triggered builds
if [[ "${BUILDKITE_SOURCE:-}" != "ui" ]]; then
  exit 0
fi

if [[ -z "${BUILDKITE_BRANCH:-}" ]]; then
  echo "ERROR: BUILDKITE_BRANCH environment variable is not set." >&2
  exit 1
fi

if [[ -z "${BUILDKITE_COMMIT:-}" ]]; then
  echo "ERROR: BUILDKITE_COMMIT environment variable is not set." >&2
  exit 1
fi

mode=$(plugin_read_config MODE "strict")

if [[ "$mode" != "warn" && "$mode" != "strict" ]]; then
  echo "ERROR: Invalid mode '$mode'. Must be 'warn' or 'strict'." >&2
  exit 1
fi

current_commit=$(git rev-parse "$BUILDKITE_COMMIT")
commit_branch=$(git name-rev --name-only "$current_commit")

if [[ "$commit_branch" != "$BUILDKITE_BRANCH" ]]; then
  if [[ "$mode" == "strict" ]]; then
    echo "ERROR: Commit branch ($commit_branch) does not match BUILDKITE_BRANCH ($BUILDKITE_BRANCH)." >&2
    exit 1
  else
    echo "WARNING: Commit branch ($commit_branch) does not match BUILDKITE_BRANCH ($BUILDKITE_BRANCH)." >&2
  fi
fi
