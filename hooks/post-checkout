#!/bin/bash

set -euo pipefail

DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

# shellcheck source=lib/plugin.bash
. "$DIR/../lib/plugin.bash"

# Only run for UI-triggered builds
if [[ "${BUILDKITE_SOURCE:-}" != "ui" ]]; then
  exit 0
fi

if [[ -z "${BUILDKITE_BRANCH:-}" ]]; then
  echo "ERROR: BUILDKITE_BRANCH environment variable is not set." >&2
  exit 1
fi

if [[ -z "${BUILDKITE_COMMIT:-}" ]]; then
  echo "ERROR: BUILDKITE_COMMIT environment variable is not set." >&2
  exit 1
fi

mode=$(plugin_read_config MODE "strict")

if [[ "$mode" != "warn" && "$mode" != "strict" ]]; then
  echo "ERROR: Invalid mode '$mode'. Must be 'warn' or 'strict'." >&2
  exit 1
fi

# Deepen history so merge-base can walk the commit graph
if [[ "$(git rev-parse --is-shallow-repository)" == "true" ]]; then
  git fetch --unshallow origin "$BUILDKITE_BRANCH"
fi

if ! git merge-base --is-ancestor "$BUILDKITE_COMMIT" "origin/$BUILDKITE_BRANCH"; then
  if [[ "$mode" == "strict" ]]; then
    echo "ERROR: Commit $BUILDKITE_COMMIT is not on branch $BUILDKITE_BRANCH." >&2
    exit 1
  else
    echo "WARNING: Commit $BUILDKITE_COMMIT is not on branch $BUILDKITE_BRANCH." >&2
  fi
fi
